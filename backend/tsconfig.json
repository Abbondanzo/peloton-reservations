{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "outDir": "build",
    "allowJs": true,
    "rootDir": "src",
    "lib": ["dom", "es6"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "build"],
  "include": ["src/**/*.ts"],
  "files": ["src/index.ts"]
}
