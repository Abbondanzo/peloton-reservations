{
  "rules": {
    ".read": false,
    "alerts": {
      ".read": "auth.uid === 'backend-service-worker'",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "alertPreferences": {
      ".read": "auth.uid === 'backend-service-worker'",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "messagingTokens": {
      ".read": "auth.uid === 'backend-service-worker'",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "admins": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": false
      }
    },
    "classHistory": {
      "$studioId": {
        ".write": "auth != null && auth.uid === 'backend-service-worker'",
        "$classId": {
          ".read": "auth != null"
        }
      }
    },
    "metrics": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && auth.uid === 'backend-service-worker'"
    }
  }
}
