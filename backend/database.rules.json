{
  "rules": {
    ".read": false,
    "alerts": {
      ".read": "auth.uid === 'backend-service-worker'",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "alertPreferences": {
      ".read": "auth.uid === 'backend-service-worker'",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "messagingTokens": {
      ".read": "auth.uid === 'backend-service-worker'",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    }
  }
}
